# Python cache / build artifacts
# ------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.pyc

# Virtual environments
.venv/
venv/
env/

